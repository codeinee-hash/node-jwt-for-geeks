{
	"compilerOptions": {
		"target": "ES2022",
		"module": "CommonJS",
		"moduleResolution": "Node",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"outDir": "dist",
		"rootDir": ".",
		"resolveJsonModule": true,
		"noImplicitReturns": true
	},
	"include": ["**/*.ts", "types/**/*.d.ts"],
	"exclude": ["node_modules", "dist"]
}
